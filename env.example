# =============================================================================
# SDP — Environment Configuration
# Copy to .env and fill in real values. Required vars (no default) will
# crash the app on startup via logrus.Fatalf if left unset.
# =============================================================================

# ----- Server -----------------------------------------------------------
APP_ENV=development
SERVER_HOST=
SERVER_PORT=8080

# ----- Database (required) -----------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sms_sdp
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL_MODE=disable

# ----- Redis -----------------------------------------------------------
# Backs the hot wallet, rate limiter state, SDP token cache, and the SSE
# pub/sub channel that the Node BFF subscribes to.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ----- RabbitMQ -----------------------------------------------------------
AMQP_URL=amqp://guest:guest@localhost:5672/

# ----- Worker Pools -----------------------------------------------------
# VIP must always have the most consumers — OTPs jump the line regardless
# of how deep the bulk campaign queue is.
WORKER_POOL_VIP=10
WORKER_POOL_STANDARD=5
WORKER_POOL_BULK=2

# ----- MNO Routing -----------------------------------------------------
# JSON array. Longest matching prefix wins. dispatcher must be one of:
# "http_at" | "http_safaricom" | "smpp"
MNO_ROUTES=[{"prefix":"2547","name":"safaricom","dispatcher":"http_safaricom","tps_limit":50},{"prefix":"2541","name":"airtel","dispatcher":"http_at","tps_limit":20},{"prefix":"2110","name":"telkom","dispatcher":"http_at","tps_limit":20}]

# ----- Africa's Talking -----------------------------------------------------
AT_API_KEY=
AT_USERNAME=
AT_BASE_URL=https://api.africastalking.com/version1/messaging

# ----- Safaricom SDP -----------------------------------------------------
SDP_CPID=
SDP_SOURCE_ADDRESS=
SDP_BULK_SMS_URL=https://dsdp-apinb.safaricom.com/api/public/CMS/bulksms
SDP_BULK_SMS_DLR_URL=https://reports-service.intouchvas.io/dlr/{type}/{outboxID}
SDP_BULK_SMS_CHANNEL=sms
SDP_SENDSMS_URL=https://dsvc.safaricom.com:8480/api/public/SDP/sendSMSRequest
SDP_SENDSMS_CHANNEL=sms
# Redis key where the auth-refresh job caches the current Bearer token.
SDP_TOKEN_REDIS_KEY=sdp:token

# Promotional / bulk SMS kill-switch — set to 1 to block a smsType at runtime.
# Read as BLOCK_<SMS_TYPE_UPPERCASE>, e.g. BLOCK_PROMOTIONAL=1
BLOCK_PROMOTIONAL=0

# ----- SMPP (not yet implemented — stub) -----------------------------------
SMPP_HOST=
SMPP_PORT=2775
SMPP_SYSTEM_ID=
SMPP_PASSWORD=
SMPP_MODE=transceiver

# ----- Hot Wallet / Core Wallet Service -----------------------------------
# How often the SDP batches accumulated Redis deductions and ships them to
# the Core Wallet Service's PostgreSQL ledger.
WALLET_FLUSH_INTERVAL=30s
# Batch flush endpoint (the Core Engine's cold ledger writer).
WALLET_SERVICE_URL=http://localhost:9090/api/v1/internal/wallet/batch-deduct
# Per-client balance check endpoint, used to seed/refresh the hot wallet.
# Maps to wallet/router.(*App).InternalBalanceCampaign-fm in the Core Engine.
WALLET_BALANCE_URL=http://localhost:9090/api/v1/internal/wallet/balance

# ----- SSE / Redis Pub/Sub -----------------------------------------------
# Channel the SDP publishes DLR events and campaign progress to. The Node
# BFF subscribes to this channel and routes messages straight to connected
# WebSocket/SSE clients — no extra plumbing needed beyond PUBLISH.
SSE_REDIS_CHANNEL=ws:messages

# ----- Auth (required) -----------------------------------------------------
JWT_SECRET=changeme

# ----- AWS S3 / Minio (bulk campaign contact files) -------------------------
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Set MINIO_ENDPOINT for local Minio; leave empty to use AWS S3 directly.
MINIO_ENDPOINT=

# ----- Debug -----------------------------------------------------------
DEBUG=0
